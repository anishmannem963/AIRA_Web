# MongoDB
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASS@cluster.mongodb.net/airadb?retryWrites=true&w=majority
DB_NAME=airadb

# JWT
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Groq API (get free key at console.groq.com)
GROQ_API_KEY=your-groq-api-key

# Encryption key for messages (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=your-fernet-encryption-key

# CORS (frontend URL)
FRONTEND_URL=http://localhost:3000
